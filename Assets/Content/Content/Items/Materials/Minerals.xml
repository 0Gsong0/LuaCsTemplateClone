<?xml version="1.0" encoding="utf-8"?>
<Items>
  <!-- 潜渊症矿物 (格式参照 - 双物品方案：矿脉 + 成品)
  
  矿脉（地形中生成，包含分解配置）
  <Item name="潜渊晶体矿脉" identifier="AbyssalCrystal_Vein_TL" category="Material" 
        maxstacksize="16" maxstacksizecharacterinventory="8" Tags="smallitem,mineral,ore" 
        canbepicked="true" cargocontaineridentifier="metalcrate" scale="0.5" 
        impactsoundtag="impact_metal_light" description="">
    
    商店配置
    <PreferredContainer primary="storagecab" />
    <PreferredContainer secondary="wreckstoragecab,abandonedstoragecab,piratestoragecab" 
                       minamount="1" maxamount="2" spawnprobability="0.05" />
    
    <Price baseprice="500" minleveldifficulty="20">
      <Price storeidentifier="merchantoutpost" multiplier="1.3" />
      <Price storeidentifier="merchantcity" multiplier="1.25" minavailable="1" />
      <Price storeidentifier="merchantresearch" multiplier="1.1" minavailable="1" />
      <Price storeidentifier="merchantmilitary" multiplier="0.9" minavailable="2" />
      <Price storeidentifier="merchantmine" multiplier="0.9" minavailable="3" />
      <Price storeidentifier="TLarmory" multiplier="0.8" minavailable="5" />
    </Price>
    
    分解配置 (用切割机切割后得到成品)
    <Deconstruct time="3">
      <Item identifier="AbyssalCrystal_TL" amount="2" />
    </Deconstruct>
    
    矿脉贴图（大块、复杂）
    <Sprite texture="%ModDir%/Content/Items/Materials/Minerals.png" 
            sourcerect="0,0,40,40" depth="0.55" origin="0.5,0.5" />
    
    物理属性
    <Body width="40" height="40" density="25" />
    
    矿物作为地形资源的配置
    <LevelResource deattachduration="1" randomoffsetfromwall="40">
      <Commonness commonness="0.1" cavecommonness="0.2" abysscommonness="0.6" />
    </LevelResource>
    
    握持配置
    <Holdable canBeCombined="true" slots="Any,RightHand,LeftHand" handle1="0,0" 
              msg="ItemMsgPickUpSelect" pickingtime="3" attachable="true" reattachable="false">
      <StatusEffect type="OnBroken" target="This">
        <Remove />
      </StatusEffect>
    </Holdable>
  </Item>
  
  成品（玩家得到的，可以卖掉）
  <Item name="潜渊晶体" identifier="AbyssalCrystal_TL" category="Material" 
        maxstacksize="32" maxstacksizecharacterinventory="8" Tags="smallitem,mineral,ore" 
        canbepicked="true" cargocontaineridentifier="metalcrate" scale="0.5" 
        impactsoundtag="impact_metal_light" description="">
    
    商店配置
    <PreferredContainer primary="storagecab" />
    <PreferredContainer secondary="wreckstoragecab,abandonedstoragecab,piratestoragecab" 
                       minamount="1" maxamount="2" spawnprobability="0.05" />
    
    <Price baseprice="300">
      <Price storeidentifier="merchantoutpost" multiplier="1.3" />
      <Price storeidentifier="merchantcity" multiplier="1.25" />
      <Price storeidentifier="merchantresearch" multiplier="1.1" />
      <Price storeidentifier="merchantmilitary" multiplier="0.9" />
      <Price storeidentifier="merchantmine" multiplier="0.9" maxavailable="10" />
    </Price>
    
    成品贴图（小块、整齐）
    <InventoryIcon texture="%ModDir%/Content/Items/Materials/Minerals.png" 
                   sourcerect="40,0,64,64" origin="0.5,0.5" />
    <Sprite texture="%ModDir%/Content/Items/Materials/Minerals.png" 
            sourcerect="40,0,40,40" depth="0.55" origin="0.5,0.5" />
    
    物理属性
    <Body width="40" height="40" density="25" />
    
    握持配置
    <Holdable canBeCombined="true" slots="Any,RightHand,LeftHand" handle1="0,0" 
              msg="ItemMsgPickUpSelect" pickingtime="1" attachable="false" reattachable="false">
      <StatusEffect type="OnBroken" target="This">
        <Remove />
      </StatusEffect>
    </Holdable>
  </Item>
  -->

  <!-- 更多潜渊症相关矿物可在下面添加 -->
<Item name="红化晶矿" identifier="Rubed_Crystal_ore" category="Material" 
        maxstacksize="16" maxstacksizecharacterinventory="8" Tags="smallitem,mineral,ore" 
        canbepicked="true" cargocontaineridentifier="metalcrate" scale="0.5" 
        impactsoundtag="impact_metal_light" description="暗红色的晶体沉积物，内部似乎有红色的微光">
    
    <!-- 商店配置 -->
    <PreferredContainer primary="storagecab" />
    <PreferredContainer secondary="wreckstoragecab,abandonedstoragecab,piratestoragecab" 
                       minamount="1" maxamount="2" spawnprobability="0.05" />
    
    <Price baseprice="500" minleveldifficulty="20">
      <Price storeidentifier="merchantoutpost" multiplier="1.3" />
      <Price storeidentifier="merchantcity" multiplier="1.25" minavailable="1" />
      <Price storeidentifier="merchantresearch" multiplier="1.1" minavailable="1" />
      <Price storeidentifier="merchantmilitary" multiplier="0.9" minavailable="2" />
      <Price storeidentifier="merchantmine" multiplier="0.9" minavailable="3" />
      <Price storeidentifier="TLarmory" multiplier="0.8" minavailable="5" />
    </Price>
    
    <!-- 分解配置-->
    <Deconstruct time="3">
      <Item identifier="Rubed_Crystal" amount="2" />
    </Deconstruct>
    
    <!--发光-->
    <LightComponent lightcolor="160,175,187,225" range="100" powerconsumption="0" flicker="0.0" flickerspeed="0.5" pulsefrequency="0.4" pulseamount="0" ison="true" drawbehindsubs="true">
      <LightTexture texture="Content/Lights/pointlight_rays.png" origin="0.5,0.5" />
    </LightComponent>
    
    <!-- 矿脉贴图（大块、复杂） -->
    <Sprite texture="%ModDir%/Assets/Content/Content/Items/Materials/红化晶矿.png" 
            sourcerect="0,0,40,40" depth="0.55" origin="0.5,0.5" />
    <!-- 挖下后的贴图，取原贴图的一小部分 -->
    <ContainedSprite texture="%ModDir%/Assets/Content/Content/Items/Materials/红化晶矿.png" usewhenattached="true" decorativespritebehavior="HideWhenNotVisible" depth="0.55" sourcerect="512,419,103,88" origin="0.5,0.5" />
    
    <!-- 物理属性 -->
    <Body width="40" height="40" density="25" />
    
    <!-- 矿物作为地形资源的配置 -->
    <LevelResource deattachduration="5" randomoffsetfromwall="80">
      <Commonness commonness="0.45" />
      <Commonness commonness="0.50" cavecommonness="0.55" abysscommonness="0.35" leveltype="europanridge" />
      <Commonness commonness="0.55" cavecommonness="0.45" abysscommonness="0.65" leveltype="theaphoticplateau" />
      <Commonness commonness="0.45" cavecommonness="0.40" abysscommonness="0.55" leveltype="thegreatsea" />
      <Commonness commonness="0.65" cavecommonness="0.35" abysscommonness="0.25" leveltype="hydrothermalwastes" />
      <!--采集工具-->
      <RequiredItem items="cuttingequipment" type="Equipped" />
    </LevelResource>
    <!-- 握持配置 -->
    <Holdable slots="Any,RightHand,LeftHand" msg="ItemMsgUsePlasmaCutter" handle1="0,0" pickingtime="5.0" attachable="true" reattachable="false" />
  </Item>
    <Item name="红化晶体" identifier="Rubed_Crystal" category="Material" description="散发微光的锯齿状结晶，似乎有微量辐射" maxstacksize="32" maxstacksizecharacterinventory="8" Tags="smallitem" canbepicked="true" cargocontaineridentifier="metalcrate" scale="0.5" impactsoundtag="impact_metal_light">
    <PreferredContainer primary="storagecab" />
    <PreferredContainer secondary="wreckstoragecab,abandonedstoragecab" minamount="1" maxamount="2" spawnprobability="0.2" />
    <Price baseprice="200" sold="true">
      <Price storeidentifier="merchantoutpost" multiplier="1.3" />
      <Price storeidentifier="merchantcity" multiplier="1.25" />
      <Price storeidentifier="merchantresearch" multiplier="1.1" />
      <Price storeidentifier="merchantmilitary" multiplier="1.1" />
      <Price storeidentifier="merchantmine" sold="true" multiplier="0.8" maxavailable="10" />
    </Price>
    <InventoryIcon texture="%ModDir%/Assets/Content/Content/Items/Materials/红化晶体.png" sourcerect="365,459,67,43" />
    <Sprite texture="%ModDir%/Assets/Content/Content/Items/Materials/红化晶体.png" sourcerect="365,459,67,43" depth="0.55" origin="0.5,0.5" />
    <Body width="67" height="43" density="25" />
    <Holdable canBeCombined="true" removeOnCombined="true" slots="Any,RightHand,LeftHand" handle1="0,0" msg="ItemMsgPickUpSelect">
      <StatusEffect type="OnBroken" target="This">
        <Remove />
      </StatusEffect>
    </Holdable>
    <AiTarget sightrange="1000" static="true" />
  </Item>

</Items>
