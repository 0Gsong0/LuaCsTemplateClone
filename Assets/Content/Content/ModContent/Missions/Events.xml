    <ScriptedEvent identifier="TL_LeoPard" commonness="110">
      <TagAction criteria="player" tag="player" />
      <SpawnAction npcsetidentifier="TLnpc" npcidentifier="TLnpc2" targettag="TLnpc2" spawnlocation="Outpost" targetmoduletags="airlock_TL" />
      <NPCWaitAction npctag="TLnpc2" wait="true" />
      <TriggerAction target1tag="TLnpc2" target2tag="player" applytotarget2="triggerer_player" radius="200" waitforinteraction="true" />
      <CheckDataAction identifier="Leo_Favorability" condition="gte 1">
        <Failure>
          <ConversationAction text="Dialogue.TL.Leo.1" targettag="triggerer_player" eventsprite="TL_LeoPard">
            <Option text="Dialogue.TL.Leo.2">
              <ConversationAction text="Dialogue.TL.Leo.3" targettag="triggerer_player" />
