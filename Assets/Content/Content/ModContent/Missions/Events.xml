    <!--站点增援-->
    <ScriptedEvent identifier="HQ_KFZY">
      <!--事件id-->
      <!--以下内容不用动，大概意思是，玩家被ai看到开始倒计时。每次等待一次循环，每次循环390s，循环结束后50的概率等待一秒 25的概率等待0.5秒 25的概率等待1.5秒-->
      <TagAction criteria="crew" tag="crew" />
      <TagAction criteria="bot" tag="bot" />
      <Label name="waitforspotting" />
      <WaitAction time="1" />
      <CheckVisibilityAction entitytag="bot" excludedentitytag="crew" targettag="crew">
        <Failure>
          <Goto name="waitforspotting" />
        </Failure>
      </CheckVisibilityAction>
      <WaitAction time="3" />
      <ConversationAction text="Dialogue.HX.HQ.1" dialogtype="Small" />
      <!--被发现ai发现时候的提示，代表有增援会到来-->
      <Label name="delay" />
      <RNGAction chance="0.5">
        <Success>
          <WaitAction time="1" />
        </Success>
        <Failure>
          <RNGAction chance="0.5">
            <Success>
              <WaitAction time="0.5" />
            </Success>
            <Failure>
              <WaitAction time="1.5" />
            </Failure>
          </RNGAction>
        </Failure>
      </RNGAction>
      <GoTo name="delay" maxtimes="240" />
      <SpawnAction npcsetidentifier="HXnpc" npcidentifier="HX_KFXD" lootingisstealing="false" targettag="HX_KFXDYY" spawnlocation="outpost" TeamID="None" allowinplayerview="false" spawnpointtag="HX_KFXD1" />
      <!--刷新出的增援的队长带个音响，这个只需要改npcid和from就行就是前两个，spawnpointtag不写的话则是随机位置，要写自己填对应的-->
      <StatusEffectAction targettag="HX_KFXDYY">
        <StatusEffect target="This">
          <Sound file="%ModDir%/Sounds/Music/OW1JS.ogg" range="99999" volume="3" Loop="true" />
          <!--bgm-->
        </StatusEffect>
      </StatusEffectAction>
      <!--以下都是增援部队 等待时间0.1，目的是为了刷怪流畅点，避免卡死-->
      <SpawnAction npcsetidentifier="HXnpc" npcidentifier="HX_KFXD" lootingisstealing="false" spawnlocation="outpost" TeamID="None" allowinplayerview="false" spawnpointtag="HX_KFXD1" />
      <WaitAction time="0.1" />
      <SpawnAction npcsetidentifier="HXnpc" npcidentifier="HX_KFXD" lootingisstealing="false" spawnlocation="outpost" TeamID="None" allowinplayerview="false" spawnpointtag="HX_KFXD1" multiplayeronly="true" />
      <WaitAction time="0.1" />
      <SpawnAction npcsetidentifier="HXnpc" npcidentifier="HX_KFXD" lootingisstealing="false" spawnlocation="outpost" TeamID="None" allowinplayerview="false" spawnpointtag="HX_KFXD1" />
      <WaitAction time="0.1" />
      <SpawnAction npcsetidentifier="HXnpc" npcidentifier="HX_KFXD" lootingisstealing="false" spawnlocation="outpost" TeamID="None" allowinplayerview="false" spawnpointtag="HX_KFXD2" />
      <WaitAction time="0.1" />
      <SpawnAction npcsetidentifier="HXnpc" npcidentifier="HX_KFXD" lootingisstealing="false" spawnlocation="outpost" TeamID="None" allowinplayerview="false" spawnpointtag="HX_KFXD2" multiplayeronly="true" />
      <WaitAction time="0.1" />
      <SpawnAction npcsetidentifier="HXnpc" npcidentifier="HX_KFXD" lootingisstealing="false" spawnlocation="outpost" TeamID="None" allowinplayerview="false" spawnpointtag="HX_KFXD2" />
      <WaitAction time="0.1" />
      <SpawnAction npcsetidentifier="HXnpc" npcidentifier="HX_KFXD" lootingisstealing="false" spawnlocation="outpost" TeamID="None" allowinplayerview="false" spawnpointtag="HX_KFXD2" />
      <WaitAction time="0.1" />
      <ConversationAction text="Dialogue.HX.HQ.2" dialogtype="Small" />
      <!--事件结束后的提示，代表增援全部到达-->
    </ScriptedEvent>
