            </Option>
            <Option text="Dialogue.TL.Leo.4">
              <ConversationAction text="Dialogue.TL.Leo.5" targettag="triggerer_player" />
              <ReputationAction targettype="Faction" identifier="TLCompany" increase="-1" />
              <SetDataAction identifier="Leo_Favorability" operation="add" value="2" />
            </Option>
          </ConversationAction>
        </Failure>
        <Success>
          <CheckDataAction identifier="Leo_Favorability" condition="gte 2">
