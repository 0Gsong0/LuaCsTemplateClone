  <Talent identifier="fightTrain" trackedstat="enemykill_counter" trackedmax="30">
    <Icon texture="%ModDir%/Content/ModContent/Job/TalentsPNG/TalentsIcons.png" sheetelementsize="128,128" sheetindex="1,0" />
    <Description tag="talentdescription.fightTrain">
      <Replace tag="[amount1]" value="30" color="gui.green" />
      <Replace tag="[amount2]" value="500" color="gui.green" />
      <Replace tag="[amount3]" value="20" color="gui.green" />
      <Replace tag="[amount4]" value="10" color="gui.green" />
    </Description>
    <AbilityGroupEffect abilityeffecttype="None">
      <Abilities>
        <CharacterAbilityGivePermanentStat statidentifier="enemykill_30" value="1" maxvalue="1" setvalue="true" />
      </Abilities>
    </AbilityGroupEffect>
    <AbilityGroupEffect abilityeffecttype="OnKillCharacter">
      <Conditions>
        <AbilityConditionCharacter targettypes="Enemy" />
      </Conditions>
      <Abilities>
        <CharacterAbilityGivePermanentStat statidentifier="enemykill_counter" value="1" />
      </Abilities>
    </AbilityGroupEffect>
    <AbilityGroupEffect abilityeffecttype="OnKillCharacter">
      <Conditions>
        <AbilityConditionHasPermanentStat statidentifier="enemykill_30" min="1" />
        <AbilityConditionHasPermanentStat statidentifier="enemykill_counter" min="30" />
      </Conditions>
      <Abilities>
        <CharacterAbilityGiveExperience amount="500" />
        <CharacterAbilityGivePermanentStat stattype="MaximumHealthMultiplier" statidentifier="fightTrain" value="0.1" setvalue="true" removeondeath="false" />
        <CharacterAbilityGivePermanentStat stattype="WeaponsSkillBonus" statidentifier="fightTrain" value="20" setvalue="true" removeondeath="false" />
        <CharacterAbilityResetPermanentStat statidentifier="enemykill_30" />
      </Abilities>
    </AbilityGroupEffect>
  </Talent>
